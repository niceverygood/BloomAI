# --- Database (Supabase Postgres) ---
# Supabase 대시보드 → Project Settings → Database → Connection string
# 앱(런타임)은 풀링(PgBouncer, 6543), 마이그레이션은 직접연결(5432) 사용.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# --- AI (Claude) ---
# 비워두면 AI 기능은 내장 데모(목업)로 동작합니다.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"
